.item {
  list-style: none;
  display: flex;
  justify-content: space-between;
}

.text {
  display: inline-block;
  margin-right: 15px;
}

.deleteBtn {
  border: 2px solid rgb(134, 5, 5);
  background: white;
  border-radius: 8px;
  padding: 5px 10px;
  margin-top: 20px;
  font-weight: 600;
}

.deleteBtn:hover {
  background-color: rgb(134, 5, 5);
  box-shadow: 0 5px 10px 2px rgb(34 60 80 / 20%);
  color: #fff;
}